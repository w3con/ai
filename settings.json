{
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "stitch-build@google-labs-code-stitch-skills": true,
    "stitch-design@google-labs-code-stitch-skills": true,
    "stitch-utilities@google-labs-code-stitch-skills": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "preferredNotifChannel": "terminal_bell",
  "theme": "auto",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(/Users/laptop/Dev/ai/bin/websearch:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/settings-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-store-guard.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER on writing style for THIS reply: write in full, connected sentences and developed prose. Never use telegraphic or clipped-fragment style, dropped subjects, or headline-style bullets. Explain terms plainly. This applies to chat answers exactly as much as to documents. Alex has demanded this many times — treat any urge to compress as the cue to slow down and spell it out.'"
          }
        ]
      }
    ]
  }
}
