#!/usr/bin/env python3
"""kb-index-hook — Claude Code PostToolUse hook.

Fires after every Write/Edit tool call. If the modified file is under kb/,
checks whether kb/_index.md is stale and regenerates it if needed.

Invoked automatically by the Claude Code harness — not meant to be run manually.
Input: JSON payload on stdin with keys tool_name, tool_input, tool_response.

Always exits 0 so it never blocks the assistant's response.
"""
import json
import os
import subprocess
import sys


def main() -> None:
    try:
        payload = json.load(sys.stdin)
        file_path = payload.get("tool_input", {}).get("file_path", "")
    except (json.JSONDecodeError, AttributeError, ValueError):
        sys.exit(0)

    # Only act when a kb/ file was touched
    if "/kb/" not in file_path and not file_path.startswith("kb/"):
        sys.exit(0)

    project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    kb_index = os.path.join(project_root, "bin", "kb-index")

    check = subprocess.run(
        [kb_index, "--check"],
        capture_output=True,
        cwd=project_root,
    )
    if check.returncode != 0:
        subprocess.run([kb_index], cwd=project_root, capture_output=True)
        print("[kb-index-hook] _index.md refreshed", file=sys.stderr)

    sys.exit(0)


if __name__ == "__main__":
    main()
