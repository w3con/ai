#!/usr/bin/env python3
"""kb-reflow — collapse hard-wrapped prose in KB markdown files.

Replaces intra-paragraph hard newlines with single spaces in body prose,
while leaving frontmatter (including the builder-owned ai: block), fenced
code blocks, headings, list items and their wrapped continuations, table
rows, blockquotes, HTML comments, horizontal rules, blank lines, and
two-trailing-space hard breaks untouched.

Safety guarantees
-----------------
Token-sequence integrity: before writing, the script verifies that the
ordered sequence of whitespace-separated tokens across the whole file is
identical before and after. Any mismatch → the file is skipped, nothing
is written, and the path is reported. This makes silent word-level
corruption impossible.

Link-integrity guard: if a [[wikilink]] or ]( URL is split across a hard
newline in the raw body, the file is flagged for manual review instead of
being joined blindly.

Idempotent: a second run over an already-reflowed file produces no change.

Usage
-----
    ai/bin/kb-reflow                    apply in place to all in-scope files
    ai/bin/kb-reflow --check            dry-run: list files that would change
    ai/bin/kb-reflow path/to/file.md    apply to specific file(s)
    ai/bin/kb-reflow --check file.md    dry-run for specific file(s)
    ai/bin/kb-reflow --self-test        run the built-in fixture self-test

File selection (no explicit paths given):
    git log --since=SINCE_DATE --name-only --pretty=format: -- 'kb/**/*.md'
    minus kb/_index.md and anything under kb/_templates/ (Templater meta).
    Board and tracker files (_contacts-board.md, _tracker.md) are included.

Never hand-edit kb/_index.md — that is generated by ai/bin/kb-index.
"""
import re
import sys
import subprocess
from pathlib import Path


PROJECT_ROOT = Path(
    subprocess.check_output(["git", "rev-parse", "--show-toplevel"], text=True).strip()
)
KB_DIR = PROJECT_ROOT / "kb"

# Files modified since this date (inclusive) form the default in-scope set.
SINCE_DATE = "2026-06-12"

# ── relation-build section delimiters ────────────────────────────────────────
RELATED_START = "<!-- relation-build:related-start -->"
RELATED_END   = "<!-- relation-build:related-end -->"

# ── Line-type patterns ────────────────────────────────────────────────────────
FENCE_RE       = re.compile(r'^(`{3,}|~{3,})')
HEADING_RE     = re.compile(r'^#{1,6}(\s|$)')
LIST_MARKER_RE = re.compile(r'^(\s*)(-|\*|\+|\d+[.)]) ')
TABLE_ROW_RE   = re.compile(r'^\|')
BLOCKQUOTE_RE  = re.compile(r'^>')
HRULE_RE       = re.compile(r'^(-{3,}|\*{3,}|_{3,})\s*$')


# ── Frontmatter extraction ────────────────────────────────────────────────────

def split_frontmatter(text: str) -> tuple[str, str]:
    """Return (frontmatter_block, body).

    frontmatter_block is the raw ---\\n...\\n---\\n string (with delimiters).
    If no frontmatter is present, frontmatter_block is '' and body is the
    full text.
    """
    m = re.match(r'^(---\n.*?\n---\n)', text, re.S)
    if m:
        return m.group(1), text[m.end():]
    return '', text


# ── Link-integrity guard ──────────────────────────────────────────────────────

def find_split_links(body: str) -> list[int]:
    """Return 1-indexed body line numbers where a [[...]] or ](...) spans a newline.

    Specifically, any line that contains an open [[ with no matching ]] before
    end-of-line, or an open ]( with no matching ) before end-of-line.

    These cases would be ambiguously joined by the reflow; we flag the file
    for manual review instead.
    """
    issues: list[int] = []
    for i, line in enumerate(body.split('\n')):
        # unclosed [[ on this line
        for m in re.finditer(r'\[\[', line):
            if ']]' not in line[m.end():]:
                issues.append(i + 1)
                break
        # unclosed ]( on this line (markdown link URL)
        for m in re.finditer(r'\]\(', line):
            if ')' not in line[m.end():]:
                issues.append(i + 1)
                break
    return issues


# ── Token sequence ────────────────────────────────────────────────────────────

def token_seq(text: str) -> list[str]:
    """Return the ordered list of whitespace-separated non-empty tokens."""
    return [t for t in re.split(r'\s+', text) if t]


# ── Body reflow ───────────────────────────────────────────────────────────────

def reflow_body(body: str) -> tuple[str, int]:
    """Collapse intra-paragraph hard newlines into spaces in body prose.

    Leaves fenced code, headings, list items (and their wrapped continuations
    joined into one line per bullet), table rows, blockquotes, HTML comments,
    the relation-build section, horizontal rules, blank lines, and hard
    breaks (two trailing spaces) exactly as they are.

    Returns (reflowed_body, collapsed_count) where collapsed_count is the
    number of newline-to-space replacements performed.

    The caller must strip frontmatter before calling this function.
    """
    lines = body.split('\n')

    output:   list[str]     = []
    buf:      list[str]     = []   # lines being accumulated
    buf_type: str | None    = None  # 'prose' or 'list'
    collapsed: int          = 0

    # processing state
    state:      str = 'normal'  # 'normal'|'code_fence'|'html_comment'|'relation_block'
    fence_char: str = ''
    fence_len:  int = 0

    def flush() -> None:
        """Emit the current buffer as one joined line, then reset."""
        nonlocal buf, buf_type, collapsed
        if not buf:
            return
        if len(buf) > 1:
            collapsed += len(buf) - 1
        output.append(' '.join(buf))
        buf = []
        buf_type = None

    for line in lines:
        raw     = line          # original text of the line (no trailing \n)
        stripped = line.rstrip()  # trailing whitespace removed; leading preserved

        # ── Fenced code block: pass through until closing fence ──────────────
        if state == 'code_fence':
            output.append(raw)
            m = FENCE_RE.match(stripped)
            if m and m.group(1)[0] == fence_char and len(m.group(1)) >= fence_len:
                state = 'normal'
            continue

        # ── Multi-line HTML comment: pass through until --> ───────────────────
        if state == 'html_comment':
            output.append(raw)
            if '-->' in stripped:
                state = 'normal'
            continue

        # ── relation-build section: verbatim until end marker ────────────────
        if state == 'relation_block':
            output.append(raw)
            if RELATED_END in stripped:
                state = 'normal'
            continue

        # ── Normal line classification ────────────────────────────────────────

        # Blank line — paragraph separator; flush any accumulated buffer
        if not stripped:
            flush()
            output.append(raw)
            continue

        # Two-trailing-space hard break — intentional Markdown break; preserve
        if raw.endswith('  '):
            flush()
            output.append(raw)
            continue

        # relation-build start marker — enter verbatim passthrough
        if RELATED_START in stripped:
            flush()
            output.append(raw)
            state = 'relation_block'
            continue

        # HTML comment start (line-leading <!--)
        if stripped.startswith('<!--'):
            flush()
            output.append(raw)
            if '-->' not in stripped:
                state = 'html_comment'
            continue

        # Fenced code block opening
        m = FENCE_RE.match(stripped)
        if m:
            flush()
            fence_char = m.group(1)[0]
            fence_len  = len(m.group(1))
            output.append(raw)
            state = 'code_fence'
            continue

        # Heading
        if HEADING_RE.match(stripped):
            flush()
            output.append(raw)
            continue

        # Table row (including |---|--- separator rows)
        if TABLE_ROW_RE.match(stripped):
            flush()
            output.append(raw)
            continue

        # Blockquote — each > line is its own boundary
        if BLOCKQUOTE_RE.match(stripped):
            flush()
            output.append(raw)
            continue

        # Horizontal rule
        if HRULE_RE.match(stripped):
            flush()
            output.append(raw)
            continue

        # List item marker — start (or continue) a list item accumulation
        if LIST_MARKER_RE.match(stripped):
            if buf_type == 'prose':
                flush()
            elif buf_type == 'list':
                # current item is done; emit it, begin the next
                flush()
            buf_type = 'list'
            buf.append(stripped)     # keep marker's leading indent
            continue

        # Plain text line — prose or list-item continuation
        if buf_type == 'list':
            # Continuation of the current list item: strip leading indent
            buf.append(stripped.strip())
        else:
            buf_type = 'prose'
            buf.append(stripped.strip())

    # End of input — flush anything remaining
    flush()

    return '\n'.join(output), collapsed


# ── Per-file processing ───────────────────────────────────────────────────────

class ReflowResult:
    """Outcome of processing one file."""
    def __init__(self, path: Path, status: str, collapsed: int = 0, detail: str = ''):
        self.path      = path
        # 'changed' | 'unchanged' | 'aborted' | 'flagged'
        self.status    = status
        self.collapsed = collapsed
        self.detail    = detail


def reflow_file(path: Path, check: bool) -> ReflowResult:
    """Reflow one markdown file.

    check=True  — dry-run: analyse but write nothing.
    check=False — apply: write reflowed content if it differs.
    """
    try:
        original = path.read_text(encoding='utf-8')
    except OSError as e:
        return ReflowResult(path, 'aborted', detail=f'read error: {e}')

    fm, body = split_frontmatter(original)

    # Link-integrity guard: flag before any join is attempted
    split_lines = find_split_links(body)
    if split_lines:
        sample = ', '.join(str(n) for n in split_lines[:5])
        detail = f'split link(s) at body line(s) {sample} — needs manual review'
        return ReflowResult(path, 'flagged', detail=detail)

    reflowed_body, collapsed = reflow_body(body)
    reflowed = fm + reflowed_body

    # Token-sequence integrity: abort on any word-level change
    before_tokens = token_seq(original)
    after_tokens  = token_seq(reflowed)
    if before_tokens != after_tokens:
        for i, (b, a) in enumerate(zip(before_tokens, after_tokens)):
            if b != a:
                detail = (f'token mismatch at position {i}: '
                          f'before={b!r} after={a!r}')
                break
        else:
            detail = (f'token count differs: '
                      f'before={len(before_tokens)} after={len(after_tokens)}')
        return ReflowResult(path, 'aborted', detail=detail)

    if reflowed == original:
        return ReflowResult(path, 'unchanged')

    if not check:
        path.write_text(reflowed, encoding='utf-8')

    return ReflowResult(path, 'changed', collapsed=collapsed)


# ── File selection ─────────────────────────────────────────────────────────────

def discover_scope() -> list[Path]:
    """Return the in-scope file list, sorted for reproducibility.

    Includes all KB notes touched since SINCE_DATE, minus:
      - kb/_index.md (generated; never hand-edit)
      - everything under kb/_templates/ (Templater meta)

    Board and tracker files whose names begin with _ (e.g. _contacts-board.md,
    _tracker.md) ARE included — they can carry hard-wrapped prose too.
    """
    try:
        raw = subprocess.check_output(
            ['git', 'log', f'--since={SINCE_DATE}', '--name-only',
             '--pretty=format:', '--', 'kb/**/*.md'],
            text=True, cwd=PROJECT_ROOT,
        )
    except subprocess.CalledProcessError as e:
        sys.exit(f'git log failed: {e}')

    paths: set[Path] = set()
    for line in raw.splitlines():
        line = line.strip()
        if not line:
            continue
        p = PROJECT_ROOT / line
        if not p.exists():
            continue
        try:
            rel = p.relative_to(KB_DIR)
        except ValueError:
            continue
        # Exclude the generated index
        if p.name == '_index.md':
            continue
        # Exclude everything under _templates/
        if rel.parts and rel.parts[0] == '_templates':
            continue
        paths.add(p)

    return sorted(paths)


# ── Built-in fixture self-test ────────────────────────────────────────────────
#
# The fixture contains every boundary kind specified in the transform contract:
# frontmatter with an ai: block, a fenced code block, a table, a task-list
# with a wrapped item, a wikilink-bullet list, a blockquote, a relation-build
# marker block, and three hard-wrapped prose paragraphs.
#
# The expected output has prose joined; every other construct is byte-identical.

FIXTURE = """\
---
title: kb-reflow self-test fixture
type: test
tags: []
ai:
  domains: ["test"]
  topics: ["fixture", "reflow"]
  entities: { people: [], orgs: [], regulations: [] }
  summary: "Fixture file for kb-reflow self-test. Contains every boundary kind."
  generated: 2026-06-26
---

# Heading — boundary, never merged

Plain prose paragraph that has been
hard-wrapped at a narrow column width
to test the reflow transform.

Another prose paragraph with
several lines joined
across three lines total.

| Column A | Column B |
|----------|----------|
| Row 1    | Data     |
| Row 2    | More     |

- [ ] Task item that wraps
  to a second continuation line
- [ ] Another task item — standalone
- Simple [[wikilink]] bullet item
- Another plain bullet

> Blockquote line one
> Blockquote line two

```python
code = "stays untouched"
wrapped_line = (
    "inside fence"
)
```

<!-- relation-build:related-start -->
## Related

[[some-doc]]  [[other-doc]]
<!-- relation-build:related-end -->

Final prose paragraph after the Related block
that should also be reflowed
across its three lines.
"""

FIXTURE_EXPECTED = """\
---
title: kb-reflow self-test fixture
type: test
tags: []
ai:
  domains: ["test"]
  topics: ["fixture", "reflow"]
  entities: { people: [], orgs: [], regulations: [] }
  summary: "Fixture file for kb-reflow self-test. Contains every boundary kind."
  generated: 2026-06-26
---

# Heading — boundary, never merged

Plain prose paragraph that has been hard-wrapped at a narrow column width to test the reflow transform.

Another prose paragraph with several lines joined across three lines total.

| Column A | Column B |
|----------|----------|
| Row 1    | Data     |
| Row 2    | More     |

- [ ] Task item that wraps to a second continuation line
- [ ] Another task item — standalone
- Simple [[wikilink]] bullet item
- Another plain bullet

> Blockquote line one
> Blockquote line two

```python
code = "stays untouched"
wrapped_line = (
    "inside fence"
)
```

<!-- relation-build:related-start -->
## Related

[[some-doc]]  [[other-doc]]
<!-- relation-build:related-end -->

Final prose paragraph after the Related block that should also be reflowed across its three lines.
"""

# Prose paragraph joins: 3+3+3 lines = 2+2+2; list continuation: 2 lines = 1
FIXTURE_EXPECTED_COLLAPSED = 7


def run_self_test() -> bool:
    """Run the built-in fixture self-test. Return True on pass, False on fail."""
    print("Running self-test...")
    errors: list[str] = []

    # Test 1: reflow output matches expected ---------------------------------
    fm, body = split_frontmatter(FIXTURE)
    reflowed_body, collapsed = reflow_body(body)
    result = fm + reflowed_body

    if result != FIXTURE_EXPECTED:
        errors.append("FAIL: reflow output does not match expected.")
        res_lines = result.splitlines()
        exp_lines = FIXTURE_EXPECTED.splitlines()
        for i, (r, e) in enumerate(zip(res_lines, exp_lines)):
            if r != e:
                errors.append(f"  First diff at line {i + 1}:")
                errors.append(f"    got:      {r!r}")
                errors.append(f"    expected: {e!r}")
                break
        else:
            errors.append(f"  Line count: got {len(res_lines)}, "
                          f"expected {len(exp_lines)}")
    else:
        print("  PASS: output matches expected.")

    # Test 2: token-sequence integrity ----------------------------------------
    if token_seq(FIXTURE) != token_seq(result):
        errors.append("FAIL: token sequences differ after reflow.")
    else:
        print("  PASS: token sequence integrity.")

    # Test 3: idempotency — second pass produces no change --------------------
    fm2, body2 = split_frontmatter(result)
    reflowed2_body, collapsed2 = reflow_body(body2)
    result2 = fm2 + reflowed2_body
    if result2 != result:
        errors.append("FAIL: second pass is not idempotent.")
        res_lines  = result.splitlines()
        res2_lines = result2.splitlines()
        for i, (r, r2) in enumerate(zip(res_lines, res2_lines)):
            if r != r2:
                errors.append(f"  First diff at line {i + 1}:")
                errors.append(f"    pass 1: {r!r}")
                errors.append(f"    pass 2: {r2!r}")
                break
    else:
        print(f"  PASS: idempotent (second pass collapsed={collapsed2}, expected 0).")

    # Test 4: collapsed count -------------------------------------------------
    if collapsed != FIXTURE_EXPECTED_COLLAPSED:
        errors.append(
            f"FAIL: collapsed={collapsed}, expected {FIXTURE_EXPECTED_COLLAPSED}."
        )
    else:
        print(f"  PASS: collapsed count = {collapsed}.")

    # Test 5: link guard finds no split links in the clean fixture ------------
    _, body_fixture = split_frontmatter(FIXTURE)
    split_links = find_split_links(body_fixture)
    if split_links:
        errors.append(
            f"FAIL: link guard found unexpected split links at lines {split_links}."
        )
    else:
        print("  PASS: link guard — no split links in fixture.")

    # Test 6: link guard correctly detects a split link ----------------------
    split_body = "Some text with [[link\nsplit across lines]] here\n"
    detected = find_split_links(split_body)
    if not detected:
        errors.append("FAIL: link guard did not detect a deliberately split [[link.")
    else:
        print(f"  PASS: link guard detected split link at line(s) {detected}.")

    if errors:
        for e in errors:
            print(e)
        return False

    print("All self-tests passed.")
    return True


# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]

    if '--self-test' in args:
        ok = run_self_test()
        sys.exit(0 if ok else 1)

    check_mode     = '--check' in args
    explicit_paths = [a for a in args if not a.startswith('--')]

    if explicit_paths:
        paths = [
            Path(p) if Path(p).is_absolute() else PROJECT_ROOT / p
            for p in explicit_paths
        ]
        missing = [p for p in paths if not p.exists()]
        if missing:
            for p in missing:
                print(f"File not found: {p}", file=sys.stderr)
            sys.exit(1)
    else:
        paths = discover_scope()
        if not paths:
            print("No in-scope files found.")
            return
        print(f"Processing {len(paths)} in-scope file(s) "
              f"(since {SINCE_DATE}, {'dry-run' if check_mode else 'apply'})...")

    results = [reflow_file(p, check=check_mode) for p in paths]

    changed   = [r for r in results if r.status == 'changed']
    unchanged = [r for r in results if r.status == 'unchanged']
    flagged   = [r for r in results if r.status == 'flagged']
    aborted   = [r for r in results if r.status == 'aborted']

    if check_mode:
        for r in changed:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"  {rel}: {r.collapsed} line break(s) would be collapsed")
        total_breaks = sum(r.collapsed for r in changed)
        print(f"\nTotal: {len(changed)} file(s) would change, "
              f"{total_breaks} line break(s) to collapse, "
              f"{len(unchanged)} already clean.")
        for r in flagged:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"FLAGGED  {rel}: {r.detail}")
        for r in aborted:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"ABORTED  {rel}: {r.detail}")
        sys.exit(0 if not changed else 1)
    else:
        for r in changed:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"  reflowed  {rel} ({r.collapsed} joins)")
        for r in flagged:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"  FLAGGED   {rel}: {r.detail}")
        for r in aborted:
            rel = r.path.relative_to(PROJECT_ROOT)
            print(f"  ABORTED   {rel}: {r.detail}")
        print(f"\nDone: {len(changed)} reflowed, {len(unchanged)} already clean, "
              f"{len(flagged)} flagged, {len(aborted)} aborted.")


if __name__ == '__main__':
    main()
